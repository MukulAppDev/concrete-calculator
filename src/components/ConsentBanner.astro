---
// Cookie consent banner. Hidden by default; shown via JS only if no prior choice,
// so it never affects CLS for returning visitors.
---

<div
  id="consent-banner"
  class="fixed inset-x-0 bottom-0 z-50 hidden border-t border-border bg-card p-4 shadow-lg"
  role="region"
  aria-label="Cookie consent"
>
  <div class="mx-auto flex max-w-5xl flex-col gap-3 md:flex-row md:items-center md:justify-between">
    <p class="text-sm text-muted-foreground">
      We use cookies for ads and analytics. See our
      <a href="/privacy-policy" class="underline hover:text-foreground">privacy policy</a>.
    </p>
    <div class="flex gap-2">
      <button
        id="consent-accept"
        type="button"
        class="rounded-md bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground hover:opacity-90"
      >
        Accept
      </button>
      <button
        id="consent-decline"
        type="button"
        class="rounded-md border border-border px-4 py-2 text-sm font-semibold text-foreground hover:bg-muted"
      >
        Decline
      </button>
    </div>
  </div>
</div>

<script>
  const banner = document.getElementById('consent-banner')
  function setConsent(value: string) {
    try {
      localStorage.setItem('cookie-consent', value)
    } catch (e) {}
    banner?.classList.add('hidden')
  }
  try {
    if (!localStorage.getItem('cookie-consent')) {
      banner?.classList.remove('hidden')
    }
  } catch (e) {}
  document.getElementById('consent-accept')?.addEventListener('click', () => setConsent('accepted'))
  document.getElementById('consent-decline')?.addEventListener('click', () => setConsent('declined'))
</script>
