---
// Simple labeled SVG diagrams for each shape. Rendered statically per shape;
// JS shows/hides the right one via data-diagram attributes.
interface Props {
  shape: 'slab' | 'footing' | 'column' | 'stairs' | 'gravel'
}
const { shape } = Astro.props
---

{
  shape === 'slab' && (
    <svg viewBox="0 0 200 110" class="h-auto w-full max-w-[220px]" aria-label="Slab diagram: length, width, and thickness" role="img">
      <g stroke="currentColor" fill="none" stroke-width="1.5">
        <path d="M30 55 L110 30 L180 50 L100 78 Z" fill="var(--color-muted)" />
        <path d="M30 55 L30 70 L100 93 L100 78 Z" fill="var(--color-border)" />
        <path d="M100 78 L100 93 L180 65 L180 50 Z" fill="var(--color-border)" />
      </g>
      <text x="60" y="26" font-size="10" fill="currentColor">Length</text>
      <text x="150" y="80" font-size="10" fill="currentColor">Width</text>
      <text x="8" y="68" font-size="10" fill="currentColor">Thick.</text>
    </svg>
  )
}
{
  shape === 'footing' && (
    <svg viewBox="0 0 200 110" class="h-auto w-full max-w-[220px]" aria-label="Footing diagram: a long narrow trench with length, width, and depth" role="img">
      <g stroke="currentColor" fill="none" stroke-width="1.5">
        <path d="M20 45 L150 30 L180 42 L50 58 Z" fill="var(--color-muted)" />
        <path d="M20 45 L20 75 L50 88 L50 58 Z" fill="var(--color-border)" />
        <path d="M50 58 L50 88 L180 72 L180 42 Z" fill="var(--color-border)" />
      </g>
      <text x="70" y="24" font-size="10" fill="currentColor">Length</text>
      <text x="160" y="60" font-size="10" fill="currentColor">Width</text>
      <text x="2" y="65" font-size="10" fill="currentColor">Depth</text>
    </svg>
  )
}
{
  shape === 'column' && (
    <svg viewBox="0 0 200 110" class="h-auto w-full max-w-[220px]" aria-label="Column diagram: a cylinder with diameter and height" role="img">
      <g stroke="currentColor" fill="none" stroke-width="1.5">
        <ellipse cx="100" cy="20" rx="30" ry="10" fill="var(--color-muted)" />
        <path d="M70 20 L70 90 A30 10 0 0 0 130 90 L130 20" fill="var(--color-border)" />
      </g>
      <text x="85" y="12" font-size="10" fill="currentColor">Dia.</text>
      <text x="140" y="60" font-size="10" fill="currentColor">Height</text>
    </svg>
  )
}
{
  shape === 'stairs' && (
    <svg viewBox="0 0 200 110" class="h-auto w-full max-w-[220px]" aria-label="Stairs diagram: steps with rise, run, and width" role="img">
      <g stroke="currentColor" fill="var(--color-muted)" stroke-width="1.5">
        <path d="M20 95 L20 75 L60 75 L60 55 L100 55 L100 35 L140 35 L140 95 Z" />
      </g>
      <text x="24" y="70" font-size="10" fill="currentColor">Run</text>
      <text x="64" y="50" font-size="10" fill="currentColor">Rise</text>
      <text x="148" y="70" font-size="10" fill="currentColor">Width →</text>
    </svg>
  )
}
{
  shape === 'gravel' && (
    <svg viewBox="0 0 200 110" class="h-auto w-full max-w-[220px]" aria-label="Gravel base diagram: an area with length, width, and depth of gravel" role="img">
      <g stroke="currentColor" fill="none" stroke-width="1.5">
        <path d="M30 50 L110 28 L180 46 L100 72 Z" fill="var(--color-muted)" />
        <path d="M30 50 L30 62 L100 85 L100 72 Z" fill="var(--color-border)" />
        <path d="M100 72 L100 85 L180 58 L180 46 Z" fill="var(--color-border)" />
        <circle cx="80" cy="50" r="2" fill="currentColor" />
        <circle cx="105" cy="44" r="2" fill="currentColor" />
        <circle cx="130" cy="52" r="2" fill="currentColor" />
        <circle cx="95" cy="58" r="2" fill="currentColor" />
      </g>
      <text x="60" y="24" font-size="10" fill="currentColor">Length</text>
      <text x="150" y="72" font-size="10" fill="currentColor">Width</text>
      <text x="8" y="62" font-size="10" fill="currentColor">Depth</text>
    </svg>
  )
}
