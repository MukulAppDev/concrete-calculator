---
import BaseLayout from '../layouts/BaseLayout.astro'
import Calculator from '../components/Calculator.astro'
import AdSlot from '../components/AdSlot.astro'
import Faq from '../components/Faq.astro'
import AffiliateList from '../components/AffiliateList.astro'
import { faqSchema, calculatorSchema } from '../scripts/schema.js'

const title = 'Concrete Calculator — Cubic Yards, Bags & Cost Estimator'
const description =
  'Free concrete calculator for slabs, footings, columns, and stairs. Get cubic yards, 60 lb and 80 lb bag counts, and estimated cost instantly. Works great on your phone at the store.'

const faqItems = [
  {
    q: 'How do I calculate how much concrete I need?',
    a: 'Multiply length × width × thickness (all in feet) to get cubic feet, then divide by 27 to get cubic yards. This calculator does the math for you, converts inches automatically, and adds a waste factor so you do not come up short mid-pour.',
  },
  {
    q: 'How many cubic feet are in a cubic yard of concrete?',
    a: 'There are 27 cubic feet in one cubic yard. A cubic yard of concrete covers about 81 square feet at a 4-inch thickness.',
  },
  {
    q: 'Should I order ready-mix or buy bags?',
    a: 'As a rule of thumb, bags make sense up to about 1 cubic yard (roughly 45 × 80 lb bags). Beyond that, ready-mix delivery is usually cheaper and far less work, though many suppliers have a 1-yard minimum plus a short-load fee.',
  },
  {
    q: 'What waste factor should I use?',
    a: 'Add 5–10% for a formed slab on a well-prepared base, and up to 15% for uneven ground, rough excavation, or complex shapes. Running out of concrete mid-pour causes a cold joint, so it is always better to have slightly too much.',
  },
  {
    q: 'How thick should a concrete slab be?',
    a: 'A standard patio or walkway slab is 4 inches thick. Driveways should be 5–6 inches, and slabs supporting heavy vehicles or equipment 6 inches or more, with rebar or wire mesh reinforcement.',
  },
]

const jsonLd = [
  calculatorSchema('Concrete Calculator', description, 'https://concretecalc.example.com/'),
  faqSchema(faqItems),
]
---

<BaseLayout title={title} description={description} canonicalPath="/" jsonLd={jsonLd}>
  <main>
    <div class="mx-auto max-w-5xl px-4 pt-8 pb-6">
      <h1 class="text-3xl font-extrabold tracking-tight text-balance md:text-4xl">Concrete Calculator</h1>
      <p class="mt-2 max-w-2xl text-muted-foreground leading-relaxed text-pretty">
        Figure out exactly how much concrete you need — in cubic yards, cubic feet, and bags — for slabs,
        footings, columns, and stairs. Free, instant, and built for use on your phone in the store aisle.
      </p>
    </div>

    <Calculator defaultShape="slab" />

    <AdSlot format="leaderboard" />

    <section class="mx-auto mt-8 w-full max-w-3xl px-4">
      <h2 class="text-2xl font-bold tracking-tight text-balance">How the math works</h2>
      <p class="mt-3 text-muted-foreground leading-relaxed">
        Concrete is sold by volume. For rectangular pours like slabs and footings, the formula is
        <strong class="text-foreground"> length × width × thickness</strong>. For round columns it is
        <strong class="text-foreground"> π × radius² × height</strong>. This calculator converts your inches to
        feet automatically, totals the cubic feet, divides by 27 to get cubic yards, and rounds bag counts up
        so you never come up short.
      </p>
      <h3 class="mt-6 text-lg font-bold">Quick reference: common slab sizes (4″ thick)</h3>
      <div class="mt-3 overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-border text-left text-muted-foreground">
              <th scope="col" class="py-2 pr-4 font-semibold">Slab size</th>
              <th scope="col" class="py-2 pr-4 font-semibold">Cubic yards</th>
              <th scope="col" class="py-2 font-semibold">80 lb bags</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-border"><td class="py-2 pr-4">6 × 6 ft</td><td class="py-2 pr-4">0.44</td><td class="py-2">20</td></tr>
            <tr class="border-b border-border"><td class="py-2 pr-4">10 × 10 ft</td><td class="py-2 pr-4">1.23</td><td class="py-2">56</td></tr>
            <tr class="border-b border-border"><td class="py-2 pr-4">12 × 12 ft</td><td class="py-2 pr-4">1.78</td><td class="py-2">80</td></tr>
            <tr class="border-b border-border"><td class="py-2 pr-4">20 × 20 ft</td><td class="py-2 pr-4">4.94</td><td class="py-2">223</td></tr>
            <tr><td class="py-2 pr-4">24 × 24 ft</td><td class="py-2 pr-4">7.11</td><td class="py-2">320</td></tr>
          </tbody>
        </table>
      </div>
      <p class="mt-2 text-xs text-muted-foreground">Values include no waste factor — add 5–10% when ordering.</p>
    </section>

    <AffiliateList />

    <AdSlot />

    <Faq items={faqItems} />
  </main>
</BaseLayout>
