---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="404 - Page Not Found | Concrete Yards Calculator"
  description="The page you are looking for does not exist."
  canonicalPath="/404"
>
  <main class="mx-auto max-w-3xl px-4 py-24 text-center">
    <h1 class="mb-4 text-6xl font-extrabold tracking-tight text-primary">404</h1>
    <h2 class="mb-6 text-3xl font-bold tracking-tight text-foreground">Page Not Found</h2>
    <p class="mb-8 text-lg text-muted-foreground">
      Oops! The page you are looking for doesn't exist, has been removed, or is temporarily unavailable.
    </p>
    <a
      href="/"
      class="inline-flex h-12 items-center justify-center rounded-md bg-primary px-8 text-base font-medium text-white transition-colors hover:opacity-90"
    >
      Go Back Home
    </a>
  </main>
</BaseLayout>
