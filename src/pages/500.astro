---
import BaseLayout from '../layouts/BaseLayout.astro'

interface Props {
    error?: unknown
}

const { error } = Astro.props
---

<BaseLayout
  title="500 - Server Error | Concrete Yards Calculator"
  description="An unexpected error occurred on our server."
  canonicalPath="/500"
>
  <main class="mx-auto max-w-3xl px-4 py-24 text-center">
    <h1 class="mb-4 text-6xl font-extrabold tracking-tight text-primary">500</h1>
    <h2 class="mb-6 text-3xl font-bold tracking-tight text-foreground">Internal Server Error</h2>
    <p class="mb-8 text-lg text-muted-foreground">
      Oops! Something went wrong on our end. We are looking into it and working to fix the issue.
    </p>
    <a
      href="/"
      class="inline-flex h-12 items-center justify-center rounded-md bg-primary px-8 text-base font-medium text-white transition-colors hover:opacity-90"
    >
      Go Back Home
    </a>
  </main>
</BaseLayout>
