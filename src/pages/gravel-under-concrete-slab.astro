---
import BaseLayout from '../layouts/BaseLayout.astro'
import Calculator from '../components/Calculator.astro'
import AdSlot from '../components/AdSlot.astro'
import Faq from '../components/Faq.astro'
import AffiliateList from '../components/AffiliateList.astro'
import { faqSchema, calculatorSchema } from '../scripts/schema.js'

const title = 'How Much Gravel Under a Concrete Slab? — Base Calculator'
const description =
  'Calculate how much gravel you need under a concrete slab. Enter your slab size and base depth to get cubic yards and tons of crushed stone — plus the right depth and stone size.'

const faqItems = [
  {
    q: 'How much gravel do I need under a concrete slab?',
    a: 'Plan on a 4-inch compacted base for patios and walkways, and 4–6 inches for driveways and garage slabs. For a 10 × 10 ft slab with 4 inches of gravel, that is about 1.23 cubic yards or roughly 1.7 tons of crushed stone. Use the calculator above for your exact size.',
  },
  {
    q: 'Do I really need gravel under a concrete slab?',
    a: 'In almost all cases, yes. A compacted gravel base provides uniform support, drains water away from the slab, and reduces cracking from soil movement and frost heave. Pouring directly on soil risks settling and early cracks.',
  },
  {
    q: 'What kind of gravel goes under concrete?',
    a: 'Crushed stone with angular edges compacts best. #57 stone (¾-inch crushed) is the most common choice; crusher run or road base works well where maximum compaction is needed. Avoid rounded pea gravel — it never locks together.',
  },
  {
    q: 'Should I compact the gravel before pouring concrete?',
    a: 'Yes — compact in 2-inch layers (lifts) with a plate compactor until the surface is firm and level. A poorly compacted base settles under the slab and is the most common cause of slab cracking.',
  },
  {
    q: 'Do I need a vapor barrier between the gravel and concrete?',
    a: 'For interior slabs (basements, garages, living space) a 10–15 mil polyethylene vapor barrier over the gravel is standard and often code-required. Exterior patios and walkways usually skip it.',
  },
]

const jsonLd = [
  calculatorSchema(
    'Gravel Under Concrete Slab Calculator',
    description,
    'https://concreteyardscalculator.com/gravel-under-concrete-slab'
  ),
  faqSchema(faqItems),
]
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath="/gravel-under-concrete-slab"
  jsonLd={jsonLd}
>
  <main>
    <div class="mx-auto max-w-5xl px-4 pt-8 pb-6">
      <h1 class="text-3xl font-extrabold tracking-tight text-balance md:text-4xl">
        How Much Gravel Under a Concrete Slab?
      </h1>
      <p class="mt-2 max-w-2xl text-muted-foreground leading-relaxed text-pretty">
        Enter your slab dimensions and base depth below to get the cubic yards and tons of crushed stone you
        need under your pour. Then switch to the Slab tab to calculate the concrete itself — same
        dimensions, one tool.
      </p>
    </div>

    <Calculator defaultShape="gravel" />

    <AdSlot format="leaderboard" />

    <section class="mx-auto mt-8 w-full max-w-3xl px-4">
      <h2 class="text-2xl font-bold tracking-tight text-balance">Recommended base depth by slab type</h2>
      <div class="mt-3 overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr class="border-b border-border text-left text-muted-foreground">
              <th scope="col" class="py-2 pr-4 font-semibold">Slab type</th>
              <th scope="col" class="py-2 pr-4 font-semibold">Gravel depth</th>
              <th scope="col" class="py-2 font-semibold">Stone type</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-border"><td class="py-2 pr-4">Patio / walkway</td><td class="py-2 pr-4">4 in</td><td class="py-2">#57 crushed stone</td></tr>
            <tr class="border-b border-border"><td class="py-2 pr-4">Shed slab</td><td class="py-2 pr-4">4 in</td><td class="py-2">#57 or crusher run</td></tr>
            <tr class="border-b border-border"><td class="py-2 pr-4">Driveway</td><td class="py-2 pr-4">4–6 in</td><td class="py-2">Crusher run / road base</td></tr>
            <tr class="border-b border-border"><td class="py-2 pr-4">Garage slab</td><td class="py-2 pr-4">4–6 in</td><td class="py-2">Crusher run, compacted in lifts</td></tr>
            <tr><td class="py-2 pr-4">Poor-draining soil</td><td class="py-2 pr-4">6–8 in</td><td class="py-2">Open-graded #57 for drainage</td></tr>
          </tbody>
        </table>
      </div>
      <h3 class="mt-6 text-lg font-bold">Base prep in four steps</h3>
      <ol class="mt-2 flex list-decimal flex-col gap-1.5 pl-5 text-muted-foreground leading-relaxed">
        <li>Excavate to slab thickness plus base depth, and grade roughly level.</li>
        <li>Spread gravel in 2-inch lifts, compacting each pass with a plate compactor.</li>
        <li>Screed the final lift level — high and low spots change your concrete volume.</li>
        <li>Add a vapor barrier for interior slabs, then form and pour.</li>
      </ol>
      <p class="mt-4 text-muted-foreground leading-relaxed">
        Once your base is calculated, use the
        <a href="/" class="font-semibold text-primary underline underline-offset-2">concrete calculator</a>
        with the same length and width to get your pour volume and bag counts.
      </p>
    </section>

    <AffiliateList
      items={[
        { name: 'Plate Compactor (rental)', note: 'Non-negotiable for a solid base', href: '#' },
        { name: '10 mil Vapor Barrier Roll', note: 'For interior and garage slabs', href: '#' },
        { name: 'Screed Board / Straightedge', note: 'Level the base before the pour', href: '#' },
        { name: 'Line Level & Stakes', note: 'Set consistent base grade', href: '#' },
      ]}
    />

    <AdSlot />

    <Faq items={faqItems} />
  </main>
</BaseLayout>
