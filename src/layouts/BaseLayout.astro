---
import '../styles/global.css'
import ConsentBanner from '../components/ConsentBanner.astro'

interface Props {
  title: string
  description: string
  canonicalPath: string
  jsonLd?: object[]
}

const { title, description, canonicalPath, jsonLd = [] } = Astro.props
const site = Astro.site ?? new URL('https://concretecalc.example.com')
const canonical = new URL(canonicalPath, site).href

const navLinks = [
  { href: '/', label: 'Concrete Calculator' },
  { href: '/how-many-bags-of-concrete', label: 'Bags of Concrete' },
  { href: '/gravel-calculator', label: 'Gravel Calculator' },
  { href: '/concrete-slab-cost', label: 'Slab Cost' },
]
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/'
---

<!doctype html>
<html lang="en" class="bg-background">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og-image.png', site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.png', site).href} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#faf7f2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#181512" media="(prefers-color-scheme: dark)" />
    {jsonLd.map((schema) => <script type="application/ld+json" set:html={JSON.stringify(schema)} />)}
    <script is:inline>
      // Set theme before paint to avoid flash. Auto (system) + manual override in localStorage.
      ;(function () {
        try {
          var stored = localStorage.getItem('theme')
          var dark =
            stored === 'dark' ||
            (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)
          if (dark) document.documentElement.classList.add('dark')
        } catch (e) {}
      })()
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground font-sans">
    <header class="border-b border-border bg-card">
      <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-3">
        <a href="/" class="flex items-center gap-2 font-bold tracking-tight text-lg" aria-label="ConcreteCalc home">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="2" y="10" width="20" height="10" rx="1" fill="var(--color-primary)"></rect>
            <path d="M4 10L8 4h8l4 6" stroke="var(--color-foreground)" stroke-width="2" stroke-linejoin="round" fill="none"></path>
          </svg>
          ConcreteCalc
        </a>
        <button
          id="theme-toggle"
          type="button"
          class="flex h-10 w-10 items-center justify-center rounded-md border border-border text-muted-foreground hover:text-foreground"
          aria-label="Toggle dark mode"
        >
          <svg class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
          </svg>
          <svg class="block dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
          </svg>
        </button>
      </div>
      <nav class="mx-auto max-w-5xl overflow-x-auto px-4" aria-label="Calculators">
        <ul class="flex gap-1 pb-2 text-sm">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={currentPath === link.href ? 'page' : undefined}
                  class={`inline-block whitespace-nowrap rounded-md px-3 py-1.5 font-medium ${
                    currentPath === link.href
                      ? 'bg-primary text-primary-foreground'
                      : 'text-muted-foreground hover:bg-muted hover:text-foreground'
                  }`}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </header>

    <slot />

    <footer class="mt-16 border-t border-border bg-card">
      <div class="mx-auto flex max-w-5xl flex-col gap-4 px-4 py-8 text-sm text-muted-foreground md:flex-row md:items-center md:justify-between">
        <p>
          Estimates only. Always confirm quantities with your supplier before ordering.
        </p>
        <ul class="flex gap-4">
          <li><a href="/privacy-policy" class="hover:text-foreground">Privacy Policy</a></li>
          <li><a href="/" class="hover:text-foreground">Home</a></li>
        </ul>
      </div>
    </footer>

    <ConsentBanner />

    <script>
      const toggle = document.getElementById('theme-toggle')
      toggle?.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark')
        try {
          localStorage.setItem('theme', isDark ? 'dark' : 'light')
        } catch (e) {}
      })
    </script>
  </body>
</html>
